{
  "name": "my-desktop-app",
  "version": "1.1.3",
  "description": "我的Electron悬浮笔记应用",
  "main": "main.js",
  "scripts": {
    "start": "electron main.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac dmg"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.yourname.memoapp",
    "productName": "随手记",
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "css/**/*",
      "js/**/*",
      "renderer.js"
    ],
    "mac": {
      "target": "dir",
      "icon": "assets/icon.icns",
      "identity": null
    }
  }
}